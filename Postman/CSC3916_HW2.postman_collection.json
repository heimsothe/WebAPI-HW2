              "    pm.expect(responseJSON).to.have.property(\"message\");",
              "    pm.expect(responseJSON).to.have.property(\"headers\");",
              "    pm.expect(responseJSON).to.have.property(\"query\");",
              "    pm.expect(responseJSON).to.have.property(\"env\");",
              "});",
              "",
              "pm.test(\"Response has correct message\", function () {",
              "    const responseJSON = pm.response.json();",
              "    pm.expect(responseJSON.message).to.eql(\"GET movies\");",
              "});",
              "",
              "pm.test(\"Response query equals request query\", function () {",
              "    const responseJSON = pm.response.json();",
              "    const requestQuery = {};",
              "    pm.request.url.query.each(function (param) {",
              "        requestQuery[param.key] = decodeURIComponent(param.value);",
              "    });",
              "    pm.expect(responseJSON.query).to.eql(requestQuery);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
